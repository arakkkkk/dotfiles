{
    "env": {
        "browser"  : true,
        "jquery"   : true,
        "node"     : true,
        "commonjs" : true,
        "es6"      : true
    },
    "extends": "eslint:recommended",
    "rules": {
        "no-undef": "warn",
        "no-useless-escape": "off",
        "no-empty": "warn",
        "no-unused-vars": "off"
    }
}
