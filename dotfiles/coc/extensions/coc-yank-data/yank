	    const ratio = parseFloat(input[i].getAttribute("data-ratio"));
	
	    for (const val of values) {
	      const url = local + "/staining_pages/" + val + ".html";
	
	      // rearange width or height
	      if (ratio > 1) {
	        h = w / ratio;
	        // if h is wider than screen.width
	        if (h > sh) {
	          w = w / 2;
	          h = w / ratio;
	        }
	      } else {
	        w = h * ratio;
	        if (w > sw) {
	          h = h / 2;
	          w = h * ratio;
	        }
	      }
	      window.open(
	        url,
	        val,
	        "left=" +
	          j +
	          "toolbar=yes,menubar=yes,scrollbars=yes,width=" +
	          w.toString() +
