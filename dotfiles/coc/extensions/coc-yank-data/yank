	def main(request):
	    content = dict(user=get_learner(request))
	
	    # content is none 
	    if not content:
	        return redirect("/account/users/login")
	    # get the latest history record user did.
	    hs = History.objects.filter(learner=content['user']).order_by("-created_date")
	    if len(hs) > 0:
	        content["latest_task"] = hs[0].task
	        content["is_achieved"] = hs[0].task
	
	        content["latest_history"] = hs[0]
	        ins = content['user'].instructor
	
	        # get the next task 
	        tasks = Task.objects.filter(instructor=ins)
	        
	        # get tasks not achieved
	        not_achieved = []
	        achieved = []
	
	        # separate achieved task and not achieved tasks
	        # Historysが持つタスクと
	        # Instructor全体のタスクをそれぞれ取り出して比較
	        # 達成していないタスク・達成しているタスクを導き出す。
	        for i in range(len(tasks)):
	            t = tasks[i]
	
	            for j in range(len(hs)):
	                h = hs[j]
	                ht = h.task
	               
	                # タスクが一致した場合
	                if t == ht:
	                     # 達成した場合
	                    if h.is_achieved:
	                        achieved.append(t)
	                    
	                    break
	            
	            else:
	                not_achieved.append(t)
	        
	        next_task = None
	        for dif in ["basic", "intermediate", "advanced"]:
	            if next_task:
	                break
	            for n in not_achieved:
	                if n.level == dif:
	                    next_task = n
	                    break
	        
	        # print(len (achieved), len(tasks))
	        if len (achieved) == len(tasks):
	            
	            content["all_achieved"] = True
	
	        content["next_task"] = next_task
	    
	    return render(request, "app/main.html", content)
