	            header = next(reader)
	            for row in reader:
	                if has_bar_in_row(row):
	                    # |で区切られてるrow dataを展開
	                    row_list = expansion_tsv_row([row])
	                    for devided_row in row_list:
	                        pqdatalist.add(devided_row)
	        # ファイルへの出力
	        for i in range(len(pqdatalist.data)):
