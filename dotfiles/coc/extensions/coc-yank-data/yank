	            return True
	    return False
	
	
	def expansion_tsv_row(row_list: list):
	    result_list = []
	    for row in row_list:
	        # | が存在する場合に処理を行う
	        if has_bar_in_row(row):
	            for i in range(len(row)):
	                if "|" in row[i]:
	                    # 以下の6行でカラムを | で分割
	                    row_a = copy(row)
	                    row_a[i] = re.split("|", row[i])[0]
