	import React, { useState, useEffect, useContext, useRef } from "react";
	import { LibGssParam } from "functions/libgssparams/LibGssParam";
	import { LibJexcel } from "functions/jexcel/LibJexcel";
	import { Options, Column } from "functions/jexcel/Jexcel";
	import { LoadingSpinner } from "components/layouts/LoadingSpinner";
	import { Row, Col, Card, Form } from "react-bootstrap";
	import { Styles } from "styles/Main";
	
	export interface Props {
	  libgssparam: LibGssParam;
	}
	
	const CreateExpTable = (instance: HTMLDivElement | null, libgssparam: LibGssParam) => {
	  if (instance === null) return;
	  const libjexcel = new LibJexcel(instance);
	  libjexcel.createData(libgssparam.exp_data.data, ["id", "name", "0", "10"]);
	  libjexcel.options.data.unshift(["id", "time", 0, 10]);
	  var columns: Column[] = [
	    { title: "", width: "0px" },
	    { title: "", width: "400px" },
	    { title: "", width: "100px" },
	    { title: "", width: "100px" }
	  ];
	  libjexcel.setColumns(columns);
	  // libjexcel.banInsert();
	  libjexcel.reflectToExpData(libgssparam.exp_data);
	  libjexcel.draw();
	  libjexcel.setReadOnly([0, 1]);
	};
	
	export const ExperimentalData = (props: Props) => {
	  const [showLoading, setShowLoading] = useState<boolean>(true);
	  const jexcel = useRef<HTMLDivElement | null>(null);
	  useEffect(() => {
	    CreateExpTable(jexcel.current, props.libgssparam);
	    setShowLoading(false);
	  }, []);
	  return (
	    <>
	      <Card style={Styles.maxHeight}>
	        <Card.Header className="text-white" id="basecolor">
	          Species
	        </Card.Header>
	        <Card.Body style={{ height: "calc(100vh - 150px)", overflowY: "scroll", padding: "10px 20px" }}>
	          {showLoading ? <LoadingSpinner /> : null}
	          <div ref={jexcel} style={{ height: "500px", width: "500px" }} />
	        </Card.Body>
	      </Card>
	    </>
	  );
	};
