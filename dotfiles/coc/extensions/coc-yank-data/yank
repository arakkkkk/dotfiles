				adding_comp.NextID = 0
				adding_comp.Head = true
			} else {
				if comp_id == 0 {
					adding_comp.Head = true
					head_comp := components.GetHead(service_id)
					head_comp.Head = false
					adding_comp.NextID = head_comp.ID
					components.Update(head_comp)
				} else {
					adding_comp.Head = false
