	<script>
	  new Vue({
	      el: '#app',
	      data: {
	          // 変数を宣言する部分
	          status: 'init',     // 状況
	          recorder: null,     // 音声にアクセスする "MediaRecorder" のインスタンス
	          audioData: [],      // 入力された音声データ
	          audioExtension: ''  // 音声ファイルの拡張子
	        },
	      methods: {
	          startRecording() {
	
	              this.status = 'recording';
	              this.audioData = [];
	              this.recorder.start(); //start()メソッドで録音開始
	
	            },
	          stopRecording() {
	
	              this.recorder.stop(); //stop()メソッドで録音停止
	              this.status = 'ready';
	
	            },
	          //ブラウザで録音された音声データの拡張子を取得
	          getExtension(audioType) {
	
	              let extension = 'wav';
	              const matches = audioType.match(/audio\/([^;]+)/); //正規表現で拡張子を取得
	
	              if(matches) {
	
	                  extension = matches[1]; //ブラウザのよって拡張子が異なる
	                  //例）chrome：wavm, firefox：ogg
	
	                }
	
	              return '.'+ extension;
	
	            }
	        },
	      mounted() {
	          // マイクアクセスの可否
	          navigator.mediaDevices.getUserMedia({ audio: true })
	          //アクセスできたら
	            .then(stream => {
	
	                this.recorder = new MediaRecorder(stream);
	                // 音声を保存する
	                this.recorder.addEventListener('dataavailable', e => {
	
	                    this.audioData.push(e.data); //audioDataに音声を格納
	                    this.audioExtension = this.getExtension(e.data.type); //拡張子を取得
	
	                  });
	
	                // 録音した音声をダウンロードする
	                // （ここをデータベースに保存する処理にする）
	                this.recorder.addEventListener('stop', () => {
	
	                    const audioBlob = new Blob(this.audioData);//音声データをBlob化
	                    const url = URL.createObjectURL(audioBlob);//音声データの保存場所（URL 絶対パス）
	
	                    //特にここ以下を変える？
	                    //タグを変えてアップロードする機能を持つタグを入れればよいのでは?
	                    let a = document.createElement('a'); //aタグオブジェクト
	                    a.href = url; //href属性を指定
	                    a.download = Math.floor(Date.now() / 1000) + this.audioExtension; //download属性を指定
	                    document.body.appendChild(a); //htmlaタグをに追加
	
	                    a.click(); //クリックしたらaタグが関連する処理を行う
	
	                  });
	                this.status = 'ready';
	
	              });
	
	        }
	    });
	</script>
