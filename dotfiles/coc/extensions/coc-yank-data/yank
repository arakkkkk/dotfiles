	            <path d="M3.5 6.5A.5.5 0 0 1 4 7v1a4 4 0 0 0 8 0V7a.5.5 0 0 1 1 0v1a5 5 0 0 1-4.5 4.975V15h3a.5.5 0 0 1 0 1h-7a.5.5 0 0 1 0-1h3v-2.025A5 5 0 0 1 3 8V7a.5.5 0 0 1 .5-.5z"/>
	          </g>
	        </svg>
	      </div>
	      <div class="scale" id="mic-red" hidden>
	        <svg xmlns="http://www.w3.org/2000/svg" width="110" height="110" viewBox="-7 -7 30 30">
	          <circle fill="white" stroke="red" stroke-width="1.7" cx="8" cy="8" r="12"/>
	          <g>
	            <path d="M5 3a3 3 0 0 1 6 0v5a3 3 0 0 1-6 0V3z"/>
	            <path d="M3.5 6.5A.5.5 0 0 1 4 7v1a4 4 0 0 0 8 0V7a.5.5 0 0 1 1 0v1a5 5 0 0 1-4.5 4.975V15h3a.5.5 0 0 1 0 1h-7a.5.5 0 0 1 0-1h3v-2.025A5 5 0 0 1 3 8V7a.5.5 0 0 1 .5-.5z"/>
	          </g>
	        </svg>
	      </div>
	    </a>
	    <a class="pointer" id="stop" hidden></a>
	  </center>
	</div>
	<a type="button" class="btn btn-success" id="next-btn" href="/app/{{task.id}}/{{next_turn}}" hidden>Next</a>
	
	
	<form class="audio_form" action="" method="POST">
	  {% csrf_token %}
	  {{ audio_form.filefield }}
	</form>
	
	<script>
	  var recorded_wavesurfer = WaveSurfer.create({
	      container: '#waveform_recorded',
	      scrollParent: false,
	      backgroundColor: '#012C3D',
	      cursorColor: '#FFFFFF',
	      waveColor: '#3786BC',
	      progressColor: '#3786BC',
	      barHeight: 3,
	      height: 100
	    });
	  var wavesurfer = WaveSurfer.create({
	      container: '#waveform',
	      scrollParent: false,
	      backgroundColor: '#012C3D',
	      cursorColor: '#FFFFFF',
	      waveColor: '#B8B6B7',
	      progressColor: '#3786BC',
	      barHeight: 3,
	      height: 100
	    });
	  var shadowing_vioce_path = "{{ task.shadowing_voice | safe }}";
	  wavesurfer.load('../../../media/' + shadowing_vioce_path);
	  // 再生が終わったら録音の停止ボタンを押す
	  wavesurfer.on('finish', function () {
	      wavesurfer.pause();
	      document.getElementById("stop").click()
	      document.getElementById("next-btn").hidden = false
	    })
	</script>
	
	
