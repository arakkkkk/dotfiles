	from copy import copy
	import re
	import csv
	
	# 行が | を持つか判定
	
	
	def has_bar_in_row(row):
	    for column in row:
	        if "|" in column:
	            return True
	    return False
	
	
	# 行のリストが | を持つか判定
	def has_bar_in_row_list(row_list: list):
	    for row in row_list:
	        if has_bar_in_row(row):
	            return True
	    return False
	
	
	def expansion_tsv_row(row_list: list):
	    result_list = []
	    for row in row_list:
	        # | が存在する場合に処理を行う
	        if has_bar_in_row(row):
	            for i in range(len(row)):
	                if "|" in row[i]:
	                    # 以下の6行でカラムを | で分割
	                    row_a = copy(row)
	                    row_a[i] = re.split("|", row[i])[0]
	                    row_b = copy(row)
	                    row_b[i] = re.split("[|\t$]", row[i])[1]
	                    result_list.append(row_a)
	                    result_list.append(row_b)
	                    break
	        else:
	            result_list.append(row)
	
	    # | がまだ存在する場合再帰的にexpantion_tsv_rowを実行
	    if has_bar_in_row_list(result_list):
	        result_list = expansion_tsv_row(result_list)
	    return result_list
	
	
	# barで分けて展開したものをファイルの保存
	def expansion_tsv(file_name):
	    result_list = []
	    with open(file_name) as f1:
	        reader = csv.reader(f1, delimiter="\t")
	        # tsvのヘッダーを飛ばす
	        header = next(reader)
	        # 行データの読み込み
	        for row in reader:
	            if has_bar_in_row(row):
	                # |で区切られてるrow dataを展開
	                row_list = expansion_tsv_row([row])
	                for devided_row in row_list:
	                    result_list.append(devided_row)
	    # ファイルへの出力
	    for row in result_list:
	        f = open("out.tsv", "w")
	        f.write(row)
	        f.close()
	
	
	def expansion_csv(file_name):
