!_TAG_FILE_FORMAT	2	/extended format; --format=1 will not append ;" to lines/
!_TAG_FILE_SORTED	1	/0=unsorted, 1=sorted, 2=foldcase/
!_TAG_PROGRAM_AUTHOR	Darren Hiebert	/dhiebert@users.sourceforge.net/
!_TAG_PROGRAM_NAME	Exuberant Ctags	//
!_TAG_PROGRAM_URL	http://ctags.sourceforge.net	/official site/
!_TAG_PROGRAM_VERSION	5.8	//
$PATH	init.vim	/^let $PATH = "~\/.pyenv\/shims:".$PATH$/;"	v
,a	plugins/fzf.vim	/^nnoremap <silent> ,a :<C-u>Ag<CR>$/;"	m
,b	plugins/fzf.vim	/^nnoremap <silent> ,b :<C-u>Buffers<CR>$/;"	m
,f	plugins/fzf.vim	/^nnoremap <silent> ,f :<C-u>ProjectFiles<CR>$/;"	m
,m	plugins/fzf.vim	/^nnoremap <silent> ,m :<C-u>History<CR>$/;"	m
:fix<CR>	plugins/ale.vim	/^map :fix<CR> :ALEFix<CR>$/;"	m
:r<CR>	plugins/neoterm.vim	/^nnoremap :r<CR> :split<CR><C-w><C-w> :term python %<CR>$/;"	m
<C-a>	init.vim	/^map! <C-a>  <C-c>^i$/;"	m
<C-a>	init.vim	/^noremap <C-a>  ^$/;"	m
<C-b>	plugins/nerdtree.vim	/^nmap <C-b> :NERDTreeToggle<CR>$/;"	m
<C-e>	init.vim	/^map! <C-e>  <C-c>$a$/;"	m
<C-e>	init.vim	/^noremap <C-e>  \$$/;"	m
<C-h>	init.vim	/^noremap <C-h> gT$/;"	m
<C-j>	init.vim	/^noremap <C-j>   5j$/;"	m
<C-k>	init.vim	/^noremap <C-k>   5k$/;"	m
<C-l>	init.vim	/^noremap <C-l> gt$/;"	m
<C-q>	plugins/neoterm.vim	/^noremap <C-q> a<C-c>$/;"	m
<C-w>	plugins/neoterm.vim	/^noremap <C-w> <C-w><C-w>$/;"	m
<S-h>	init.vim	/^noremap <S-h>   ^$/;"	m
<S-j>	init.vim	/^noremap <S-j>   }$/;"	m
<S-k>	init.vim	/^noremap <S-k>   {$/;"	m
<S-l>	init.vim	/^noremap <S-l>   \$$/;"	m
<c-t>	plugins/neoterm.vim	/^nnoremap <c-t> <C-c>:Ttoggle<CR><C-w><C-w><C-c>$/;"	m
SetOption	colors/solarized.vim	/^function! s:SetOption(name,default)$/;"	f
SolarizedHiTrail	colors/solarized.vim	/^augroup SolarizedHiTrail$/;"	a
SolarizedHiTrail	colors/solarized.vim	/^function! s:SolarizedHiTrail()$/;"	f
SolarizedMenu	colors/solarized.vim	/^function! SolarizedMenu()$/;"	f
SolarizedOptions	colors/solarized.vim	/^    command SolarizedOptions :call s:SolarizedOptions()$/;"	c
SolarizedOptions	colors/solarized.vim	/^function! s:SolarizedOptions()$/;"	f
SyntaxInfo	colors/func.vim	/^command! SyntaxInfo call s:get_syn_info()r$/;"	c
T	plugins/neoterm.vim	/^command! -nargs=* T split | wincmd j | resize 20 | terminal <args>$/;"	c
colors_name	colors/solarized.vim	/^let colors_name = "solarized"$/;"	v
fd	plugins/fzf.vim	/^nnoremap <silent>fd :Files<CR>$/;"	m
