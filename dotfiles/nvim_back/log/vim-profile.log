                                            else
                                                keepjumps call cursor(foldclosedend(pos[0]+1), 0)
                                            endif
                                        else
                                            call add(targets, pos)
                                        endif
                                        "}}}
                                        let pos = searchpos(regexp, search_direction, search_stopline)
