                                    let s:flag.dot_repeat = 1
                                    let s:flag.within_line = s:dot_repeat.line_flag
                                    let s:flag.bd_t = s:dot_repeat.bd_t_flag
                                    let s:current.is_operator = 1
                            
                                    let s:flag.count_dot_repeat = (i > 0 ? 1 : 0)
